# For running the api outside docker (uv run uvicorn / pytest / make eval):
# cp .env.example .env — pydantic-settings reads backend/.env with the CODEDOC_ prefix.
# Full key list with defaults: src/codedoc/settings.py

# required
CODEDOC_OPENAI_API_KEY=sk-your-key-here

# common overrides (defaults shown)
#CODEDOC_OPENSEARCH_URL=http://localhost:9200
#CODEDOC_CHAT_MODEL_NAME=gpt-5.4-mini
#CODEDOC_EMBEDDING_MODEL_NAME=text-embedding-3-large
#CODEDOC_SEARCH_TOP_K=8
#CODEDOC_MAX_TOOL_CALLS=8
#CODEDOC_KNN_WEIGHT=0.7
#CODEDOC_BM25_WEIGHT=0.3
#CODEDOC_CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
